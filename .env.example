# =====================================================================
# F1 2026 Prediction Center — environment variable template
# =====================================================================
# 1. Copy this file to `.env` for local development:
#       cp .env.example .env       (macOS/Linux)
#       Copy-Item .env.example .env  (PowerShell)
#
# 2. Edit `.env` with your local values. The real `.env` file is
#    listed in `.gitignore` and must NEVER be committed.
#
# 3. In production (Streamlit Community Cloud, Render, Fly.io, etc.)
#    set these variables through the platform's UI rather than
#    shipping a .env file.
# =====================================================================


# --- Streamlit server tuning ---------------------------------------
# These are already baked into the Docker image (see Dockerfile).
# Uncomment here only if you want to override locally without rebuilding.
#
# STREAMLIT_SERVER_PORT=8501
# STREAMLIT_SERVER_ADDRESS=0.0.0.0
# STREAMLIT_SERVER_HEADLESS=true
# STREAMLIT_BROWSER_GATHER_USAGE_STATS=false


# --- Application secrets -------------------------------------------
# No real secrets are required today. When/if any are introduced
# (e.g. an external model-registry token, an analytics key, a
# database URL), document them in this section with placeholder
# values like the example below.
#
# EXAMPLE_API_KEY=replace-me-with-a-real-token
# EXAMPLE_DATABASE_URL=postgresql://user:password@host:5432/db
